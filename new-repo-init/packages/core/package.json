{
  "name": "@katalon/core",
  "version": "7.0.0",
  "description": "Core business logic for Katalon Recorder",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "import": "./dist/commands/index.js"
    },
    "./locators": {
      "types": "./dist/locators/index.d.ts",
      "import": "./dist/locators/index.js"
    },
    "./recorder": {
      "types": "./dist/recorder/index.d.ts",
      "import": "./dist/recorder/index.js"
    },
    "./player": {
      "types": "./dist/player/index.d.ts",
      "import": "./dist/player/index.js"
    },
    "./healing": {
      "types": "./dist/healing/index.d.ts",
      "import": "./dist/healing/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "expr-eval": "^2.0.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "peerDependencies": {},
  "license": "Apache-2.0"
}
