{
  "name": "@katalon/extension",
  "version": "7.0.0",
  "description": "Katalon Recorder browser extension",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf .output .wxt dist"
  },
  "dependencies": {
    "@katalon/core": "workspace:*",
    "@katalon/ai": "workspace:*",
    "@katalon/formatters": "workspace:*",
    "pinia": "^2.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/chrome": "^0.0.260",
    "@vitejs/plugin-vue": "^5.0.0",
    "@wxt-dev/module-vue": "^1.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0",
    "vue-tsc": "^2.0.0",
    "wxt": "^0.19.0"
  },
  "license": "Apache-2.0"
}
